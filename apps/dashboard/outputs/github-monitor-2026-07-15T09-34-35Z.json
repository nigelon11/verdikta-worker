        "variant": "default"
      }
    },
    "badge-docs": {
      "type": "Badge",
      "props": {
        "text": "verdikta-docs: ok",
        "variant": "default"
      }
    },
    "badge-road": {
      "type": "Badge",
      "props": {
        "text": "verdikta-roadmap: ok",
        "variant": "default"
      }
