      "type": "TweetCard",
      "props": {
        "text": "The honest dogfooding data point: 8 open math bounties (Vaught's Conjecture, Busy Beaver BB(6), Frankl's Union-Closed Conjecture, and 5 more) expired this week. Zero valid submissions. Real bounties, real deadlines, no shortcuts on reporting the miss."
      }
    },
    "tweet-5": {
      "type": "TweetCard",
      "props": {
        "text": "Meanwhile a housekeeping PR — \"add backlog workflow guidance\" — sits open as a draft across 4 repos, unchanged for ~135 hours. Noted, not hidden."
      }
    },
